{
  "name": "voice-tool-call",
  "version": "0.2.3",
  "description": "Voice-to-tool-call browser library: wake word detection, speech-to-text, LLM intent interpretation, tool execution, and text-to-speech",
  "type": "module",
  "main": "dist/voice-tool-call.cjs",
  "module": "dist/voice-tool-call.mjs",
  "types": "dist/types/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/voice-tool-call.mjs"
      },
      "require": {
        "types": "./dist/types/index.d.ts",
        "default": "./dist/voice-tool-call.cjs"
      }
    },
    "./node": {
      "import": "./src/lib/node.ts",
      "require": "./src/lib/node.ts",
      "types": "./src/lib/node.ts"
    }
  },
  "files": [
    "dist",
    "src/lib",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "dev": "vite",
    "build": "vite build -c vite.config.lib.ts && tsc -p tsconfig.lib.json",
    "build:example": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "demo:server": "bun examples/node/server.ts",
    "demo:cli": "bun examples/node/cli.ts",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "voice",
    "speech",
    "tool-calling",
    "wake-word",
    "speech-recognition",
    "tts",
    "text-to-speech",
    "web-speech-api",
    "browser",
    "kokoro",
    "gemini-nano"
  ],
  "license": "MIT",
  "author": "Nano112",
  "repository": {
    "type": "git",
    "url": "https://github.com/Nano112/voice-tool-call"
  },
  "homepage": "https://github.com/Nano112/voice-tool-call#readme",
  "bugs": {
    "url": "https://github.com/Nano112/voice-tool-call/issues"
  },
  "peerDependencies": {
    "kokoro-js": "^1.2.1",
    "node-llama-cpp": "^3.18.0"
  },
  "peerDependenciesMeta": {
    "kokoro-js": {
      "optional": true
    },
    "node-llama-cpp": {
      "optional": true
    }
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "electron": "^41.0.3",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "kokoro-js": "^1.2.1",
    "node-llama-cpp": "^3.18.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1",
    "vite": "^8.0.0"
  }
}
